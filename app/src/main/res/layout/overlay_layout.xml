<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_widget"
    android:elevation="8dp"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Drag Handle / App Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:text="⚡ DR. CLICKER"
        android:textColor="#FFFFD700"
        android:textSize="10sp"
        android:textStyle="bold" />

    <!-- Live status indicator -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/overlayStatusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_status_dot_active" />

        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RUNNING"
            android:textColor="#FF4CAF50"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Accept count -->
    <TextView
        android:id="@+id/tvOverlayAccepted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Accepted: 0"
        android:textColor="#FFFFFFFF"
        android:textSize="10sp" />
</LinearLayout>
